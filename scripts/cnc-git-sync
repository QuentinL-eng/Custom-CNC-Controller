#!/bin/sh
set -eu

repo=${CNC_CONTROLLER_REPO:-/home/quentin/Custom-CNC-Controller}
cd "$repo"

record_status() {
    result=$1
    commit=$2
    message=$3
    pulled=${4:-no}
    if [ -x .venv/bin/python ]; then
        if [ "$pulled" = yes ]; then
            .venv/bin/python -m cnc_controller.update_status record \
                --result "$result" --commit "$commit" \
                --message "$message" --pulled
        else
            .venv/bin/python -m cnc_controller.update_status record \
                --result "$result" --commit "$commit" \
                --message "$message"
        fi
    fi
}

commit=$(git rev-parse --short HEAD)

if [ -n "$(git status --porcelain)" ]; then
    message="Sync skipped: working tree has local changes."
    record_status skipped "$commit" "$message"
    echo "$message"
    exit 0
fi

# Retry the fetch: right after boot the timer can fire before DNS is ready
# (network-online.target is reached before name resolution actually works),
# which would otherwise record a spurious "failed" status every cold boot.
fetch_ok=no
attempt=1
while [ "$attempt" -le 5 ]; do
    if git fetch --quiet origin main; then
        fetch_ok=yes
        break
    fi
    attempt=$((attempt + 1))
    sleep 10
done

if [ "$fetch_ok" != yes ]; then
    message="Update check failed while contacting GitHub."
    record_status failed "$commit" "$message"
    echo "$message"
    exit 1
fi

if git merge-base --is-ancestor HEAD origin/main; then
    if [ "$(git rev-parse HEAD)" != "$(git rev-parse origin/main)" ]; then
        git merge --ff-only origin/main
        commit=$(git rev-parse --short HEAD)
        # Optional/laser dependencies (e.g. rayforge -> pycairo) may fail to
        # build on a minimal system that lacks the cairo dev headers. That must
        # NOT fail the whole update: the core UI runs on system Python without
        # them and the laser screen degrades gracefully. Record a note instead
        # of aborting, so code updates always land and this script self-installs.
        dep_note=""
        if ! .venv/bin/python -m pip install --quiet -e ".[cnc]"; then
            dep_note=" (some optional dependencies did not install; core app unaffected)"
        fi
        if [ -f scripts/cnc-git-sync ]; then
            install -m 0755 scripts/cnc-git-sync \
                /home/quentin/.local/bin/cnc-git-sync
        fi
        message="Updated to $commit. Restart the UI to load the new code.$dep_note"
        record_status updated "$commit" "$message" yes
        echo "$message"
    else
        message="Already current at $commit."
        record_status current "$commit" "$message"
        echo "$message"
    fi
else
    message="Sync skipped: local and remote branches have diverged."
    record_status failed "$commit" "$message"
    echo "$message"
    exit 1
fi
